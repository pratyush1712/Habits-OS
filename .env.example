# HabitOS environment configuration.
#
# Copy to `.env` and fill in. `.env` itself is gitignored.
# Milestones 1 and 2 (renderer + rule engine on local JSON) need none of these.
# Milestone 3 onwards uses MongoDB as the persistence layer.

# ---------------------------------------------------------------------------
# MongoDB connection
# ---------------------------------------------------------------------------

# Connection string. Local example:
#   mongodb://localhost:27017
# Atlas example:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# Database name. Anything; HabitOS will create collections on first write.
MONGODB_DB_NAME=habitos

# Optional: separate URI used by the repository integration tests. Tests are
# skipped automatically when this is unset. Point at a dev Mongo you don't
# mind being dropped — every test run creates and tears down a uniquely-named
# database under this connection.
#   MONGODB_TEST_URI=mongodb://localhost:27017

# ---------------------------------------------------------------------------
# API configuration (Milestone 3)
# ---------------------------------------------------------------------------

# IANA timezone name used when ingesting manual events without an explicit tz.
HABITOS_TIMEZONE=EST

# Optional override for the directory the renderer writes PDFs into.
# Defaults to data/generated/ relative to the repo root.
# HABITOS_OUTPUT_DIR=data/generated

# ---------------------------------------------------------------------------
# Automation / nightly scheduler configuration (Milestone 6)
# ---------------------------------------------------------------------------

# Enable the in-process nightly scheduler.
HABITOS_SCHEDULER_ENABLED=true

# Local time for the nightly scheduler.
HABITOS_NIGHTLY_RUN_HOUR=3
HABITOS_NIGHTLY_RUN_MINUTE=0

# Rolling WHOOP reconciliation window in days.
HABITOS_RECONCILE_DAYS=14

# Default WHOOP external user id used by the nightly automation route/job.
HABITOS_DEFAULT_WHOOP_EXTERNAL_USER_ID=""

# Whether automation should also prepare/upload the current month to reMarkable.
HABITOS_AUTO_UPLOAD_REMARKABLE=true

# With the manual adapter, this still returns instructions only.
HABITOS_REMARKABLE_DRY_RUN=false

# ---------------------------------------------------------------------------
# reMarkable sync adapter (Milestone 8 — rmapi)
# ---------------------------------------------------------------------------

# Which adapter handles reMarkable sync. `manual` returns upload instructions
# only (default, safe). `rmapi` performs automated cloud sync via the
# ddvk/rmapi CLI — install and authenticate it yourself first
# (https://github.com/ddvk/rmapi).
HABITOS_REMARKABLE_ADAPTER=rmapi

# Absolute path or PATH-resolvable binary name. With `go install` on macOS
# the absolute path is typically $HOME/go/bin/rmapi.
HABITOS_RMAPI_BINARY=~/go/bin/rmapi

# Optional dedicated rmapi config file. Recommended so HabitOS uses an
# isolated token separate from your interactive rmapi usage:
HABITOS_RMAPI_CONFIG_PATH=~/.config/habitos/rmapi.conf

# Per-command timeout in seconds.
HABITOS_RMAPI_TIMEOUT_SECONDS=60

# Set true to forward RMAPI_TRACE=1 to rmapi for verbose debugging.
HABITOS_RMAPI_TRACE=false

# Refresh the current-month dashboard data while KEEPING handwritten
# annotations (default). HabitOS downloads the existing document, swaps only the
# base PDF, and re-uploads with the ink layers intact. Requires a page-stable
# layout: if the rendered PDF's page count differs from the device's, the sync
# aborts rather than risk misplacing annotations.
HABITOS_RMAPI_PRESERVE_ANNOTATIONS=true

# Set true to REPLACE the current-month dashboard with `put --force`, discarding
# any annotations on it (a clean reset). Takes precedence over
# HABITOS_RMAPI_PRESERVE_ANNOTATIONS. Archive paths are always frozen regardless.
HABITOS_RMAPI_REPLACE_EXISTING_CURRENT=false

# Top-level folder on the device that HabitOS is allowed to write to. The
# adapter refuses any path outside this root.
HABITOS_REMARKABLE_MACHINE_ROOT=HabitOS

# ---------------------------------------------------------------------------
# WHOOP OAuth/API configuration (Milestone 4)
# ---------------------------------------------------------------------------

# Create an app in the WHOOP Developer Dashboard and register this redirect URI.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8083/whoop/oauth/callback

# Minimum useful scopes for workout/sleep/recovery sync. `offline` is required
# for refresh tokens; `read:profile` lets HabitOS discover the WHOOP user id
# during OAuth callback.
WHOOP_SCOPES=offline read:workout read:sleep read:recovery read:profile

WHOOP_API_BASE_URL=https://api.prod.whoop.com/developer
WHOOP_AUTH_URL=https://api.prod.whoop.com/oauth/oauth2/auth
WHOOP_TOKEN_URL=https://api.prod.whoop.com/oauth/oauth2/token

# Later webhook support. Do not commit real secrets.
WHOOP_WEBHOOK_SECRET=

# Required before hosted use if tokens are stored outside local development.
# HABITOS_TOKEN_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Day One integration (local SQLite, read-only, metadata-only)
# ---------------------------------------------------------------------------
# HabitOS reads the macOS Day One app's local SQLite database to detect
# whether you journaled on a given day. The default mode is metadata-only:
# entry text is NEVER read or persisted, and word counts are skipped unless
# DAYONE_INCLUDE_TEXT is explicitly opted-in. Leave DAYONE_DB_PATH empty to
# disable the integration entirely (nightly automation will skip it cleanly).
#
# Granting Full Disk Access to the process that runs HabitOS may be required
# on macOS so sqlite3 can read the Day One Group Container.

# Only "sqlite" is implemented for MVP. "mcp" and "export" are reserved.
DAYONE_SYNC_MODE=sqlite

# Path to the live Day One database. Example (macOS Mac App Store build):
# DAYONE_DB_PATH=~/Library/Group Containers/5U8NS4GX82.dayoneapp2/Data/Documents/DayOne.sqlite
DAYONE_DB_PATH="~/Library/Group Containers/5U8NS4GX82.dayoneapp2/Data/Documents/DayOne.sqlite"

# Opt-in to deriving a per-day word count from ZMARKDOWNTEXT length. Even
# when true, raw entry text is never persisted in source_events.raw_payload.
DAYONE_INCLUDE_TEXT=true

# Rolling reconciliation window. Recent days are re-read on each nightly run
# so backdated edits are captured. 3 is a reasonable default for journaling.
DAYONE_LOOKBACK_DAYS=4

# Optional comma-separated list of Day One journal names to include. Empty
# means "all visible, non-trash journals."
# DAYONE_JOURNAL_FILTER=Personal,Work
DAYONE_JOURNAL_FILTER=

# Fallback IANA timezone name when an entry's ZTIMEZONE blob cannot be parsed
# (it is a BLOB in current Day One schemas, so we don't try). Used only as
# the SourceEvent.timezone label; local_date itself is taken from Day One's
# own ZGREGORIANYEAR/MONTH/DAY columns.
DAYONE_TIMEZONE=EST
