{
  "name": "HabitOS Design Tokens",
  "version": "1.0.0",
  "source": "apps/admin/app/globals.css",
  "colors": {
    "paper": {
      "oklch": "oklch(96% 0.04 92)",
      "hex": "#F5F0E8",
      "description": "Primary background; warm off-white"
    },
    "paperDeep": {
      "oklch": "oklch(91% 0.055 88)",
      "hex": "#E8DED0",
      "description": "Secondary background; muted warm tan"
    },
    "rule": {
      "oklch": "oklch(19% 0.018 260)",
      "hex": "#2A2A30",
      "description": "Primary borders and rules; near-black blue-gray"
    },
    "ruleSoft": {
      "oklch": "oklch(72% 0.035 88)",
      "hex": "#B8B0A4",
      "description": "Subtle dividers and inactive borders"
    },
    "ink": {
      "oklch": "oklch(17% 0.02 260)",
      "hex": "#242429",
      "description": "Primary text; near-black with slight blue cast"
    },
    "inkMid": {
      "oklch": "oklch(31% 0.026 260)",
      "hex": "#3F3F48",
      "description": "Secondary headings and emphasis"
    },
    "inkFaint": {
      "oklch": "oklch(45% 0.026 260)",
      "hex": "#5C5C66",
      "description": "Tertiary text and captions"
    },
    "inkGhost": {
      "oklch": "oklch(63% 0.026 260)",
      "hex": "#82828F",
      "description": "Placeholder and disabled text"
    },
    "accent": {
      "oklch": "oklch(48% 0.18 257)",
      "hex": "#3B6BC0",
      "description": "Primary action and interactive elements"
    },
    "accentHot": {
      "oklch": "oklch(75% 0.19 142)",
      "hex": "#2ECC71",
      "description": "Positive/success emphasis"
    },
    "warningPanel": {
      "oklch": "oklch(91% 0.14 91)",
      "hex": "#F5E6C8",
      "description": "Warning and selection highlight background"
    },
    "bluePanel": {
      "oklch": "oklch(89% 0.085 230)",
      "hex": "#C8D8F0",
      "description": "Informational panel background"
    },
    "greenPanel": {
      "oklch": "oklch(86% 0.12 145)",
      "hex": "#B8E6C8",
      "description": "Success panel background"
    },
    "redPanel": {
      "oklch": "oklch(58% 0.18 28)",
      "hex": "#C8503C",
      "description": "Error/danger panel background"
    },
    "anomaly": {
      "oklch": "oklch(48% 0.19 28)",
      "hex": "#B04030",
      "description": "Destructive text and critical alerts"
    }
  },
  "shadcnTheme": {
    "background": "paper",
    "foreground": "ink",
    "card": "#FFFFFF",
    "cardForeground": "ink",
    "popover": "#FFFFFF",
    "popoverForeground": "ink",
    "primary": "accent",
    "primaryForeground": "#FFFFFF",
    "secondary": "warningPanel",
    "secondaryForeground": "ink",
    "muted": "paperDeep",
    "mutedForeground": "inkFaint",
    "accent": "accent",
    "accentForeground": "#FFFFFF",
    "destructive": "anomaly",
    "destructiveForeground": "#FFFFFF",
    "border": "rule",
    "input": "rule",
    "ring": "accent",
    "sidebar": "warningPanel",
    "sidebarForeground": "ink",
    "sidebarPrimary": "accent",
    "sidebarPrimaryForeground": "#FFFFFF",
    "sidebarAccent": "bluePanel",
    "sidebarAccentForeground": "ink",
    "sidebarBorder": "rule",
    "sidebarRing": "accent"
  },
  "typography": {
    "family": {
      "sans": ["Arial", "Helvetica Neue", "Helvetica", "sans-serif"],
      "serif": ["Arial", "Helvetica Neue", "Helvetica", "sans-serif"],
      "mono": ["JetBrains Mono", "ui-monospace", "Menlo", "monospace"]
    },
    "size": {
      "display": { "value": "6rem", "lineHeight": 0.92, "letterSpacing": "-0.05em", "weight": 950 },
      "h1": { "value": "3rem", "lineHeight": 0.98, "letterSpacing": "-0.035em", "weight": 950 },
      "h2": { "value": "2rem", "lineHeight": 1.05, "letterSpacing": "-0.02em", "weight": 900 },
      "h3": { "value": "1.25rem", "lineHeight": 1.15, "letterSpacing": "-0.01em", "weight": 800 },
      "body": { "value": "1.125rem", "lineHeight": 1.42, "letterSpacing": "0", "weight": 700 },
      "data": { "value": "0.9375rem", "lineHeight": 1.35, "letterSpacing": "0", "weight": 700 },
      "meta": { "value": "0.75rem", "lineHeight": 1.3, "letterSpacing": "0.08em", "weight": 800 }
    }
  },
  "spacing": {
    "grid": "36px",
    "panelPadding": "20px",
    "sectionGap": "18px",
    "elementGap": "12px"
  },
  "radius": {
    "none": "0px",
    "chip": "0px"
  },
  "borders": {
    "heavy": "4px solid",
    "light": "1px solid"
  },
  "animation": {
    "easeOut": "cubic-bezier(0.2, 0, 0, 1)",
    "durDisclosure": "120ms",
    "durFocus": "80ms",
    "durPulse": "2400ms"
  },
  "background": {
    "grid": {
      "size": "36px",
      "opacity": 0.08,
      "color": "rule"
    }
  }
}
